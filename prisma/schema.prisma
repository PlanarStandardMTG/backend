// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  username              String    @unique
  password              String
  admin                 Boolean   @default(false)
  tournamentOrganizer   Boolean   @default(false)
  blogger               Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // user no longer directly references matches or challonge connections
  // rankedInfo remains the central link to matchmaking and external accounts
  rankedInfo            RankedUserInfo?       @relation(fields: [rankedInfoId], references: [id])
  rankedInfoId          String?  @unique
}

model Match {
  id               String    @id @default(uuid())

  // only ranked-user relationships now
  player1RankedId  String
  player2RankedId  String

  draw             Boolean   @default(false)
  winnerRankedId   String?

  player1Score       Int?
  player2Score       Int?

  tournamentId     String?  // optional link to a tournament
  
  player1Ranked    RankedUserInfo @relation("rankedPlayer1", fields: [player1RankedId], references: [id], onDelete: Cascade)
  player2Ranked    RankedUserInfo @relation("rankedPlayer2", fields: [player2RankedId], references: [id], onDelete: Cascade)
  winnerRanked     RankedUserInfo? @relation("winnerRanked", fields: [winnerRankedId], references: [id])

  tournament        Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  player1EloChange  Int?
  player2EloChange  Int?
  
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  
  @@index([player1RankedId])
  @@index([player2RankedId])
  @@index([tournamentId])
}

model ChallongeConnection {
  id                  String    @id @default(uuid())

  accessToken         String?
  refreshToken        String?
  expiresAt           DateTime?
  scope               String?
  challongeUsername   String   @unique
  
  // linked ranked record, which in turn may point to a user
  rankedInfo         RankedUserInfo? @relation(fields: [rankedInfoId], references: [id])
  rankedInfoId       String?  @unique
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model RankedUserInfo {
  id               String    @id @default(uuid())
  userId           String?   @unique
  connectionId     String?   @unique
  username         String    @unique
  elo              Int       @default(1600)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User?
  connection       ChallongeConnection?

  matchesAsPlayer1 Match[]   @relation("rankedPlayer1")
  matchesAsPlayer2 Match[]   @relation("rankedPlayer2")
  wonMatches       Match[]   @relation("winnerRanked")
}

model Tournament {
  id                    String    @id @default(uuid())
  challongeId           String    @unique

  name                  String
  tournamentType        String
  url                   String?
  state                 String?
  startsAt              DateTime?
  gameName              String?
  participantCount      Int       @default(0)
  ratingsUpdated        Boolean   @default(false)
  
  matches               Match[]

  lastSyncedAt          DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([challongeId])
}

